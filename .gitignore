# macOS
.DS_Store

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Timestamped backup files — committed snapshots live in configs/ only
backups/network-configs/*.txt

# AI Mentor KB — generated artifact, rebuilt from docs on demand
# Do not commit chunks.jsonl — it is regenerated by scripts/ingest_docs.py
data/kb/chunks.jsonl

# Local student rosters — may contain onboarding data; commit samples only
students.csv
**/students.csv

# Secrets — never commit
.env
*.key
*.pem
